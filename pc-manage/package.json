{
  "name": "pc-manage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "dev:prod": "vite --mode prod",
    "build": "vue-tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "postinstall": "npx simple-git-hooks",
    "lint": "eslint . --fix --ext .js,.mjs,.cjs,.ts,.vue"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.2",
    "element-plus": "^2.13.0",
    "js-base64": "^3.7.8",
    "pinia": "^3.0.4",
    "vant": "^4.9.22",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vant/auto-import-resolver": "^1.3.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "less": "^4.5.1",
    "less-loader": "^12.3.0",
    "prettier": "^3.3.3",
    "simple-git-hooks": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.52.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{ts,tsx,js,jsx,vue}": "eslint --fix",
    "*.{ts,tsx,js,jsx,vue,less,css,md}": "prettier --write"
  }
}